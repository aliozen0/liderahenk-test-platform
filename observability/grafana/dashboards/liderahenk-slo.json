{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Servis Durumu",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "liderapi İstek/sn ve Hata Oranı",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"liderapi\"}[1m])",
          "legendFormat": "Toplam İstek/sn",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"liderapi\",status=~\"5..\"}[1m])",
          "legendFormat": "5xx Hata/sn",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "lider-core JVM Heap Kullanımı",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"lider-core\",area=\"heap\"} / jvm_memory_max_bytes{job=\"lider-core\",area=\"heap\"}",
          "legendFormat": "Heap Kullanımı",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Görev Gecikmesi p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"liderapi\"}[5m]))",
          "legendFormat": "p95 Gecikme",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["liderahenk", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "LiderAhenk SLO Dashboard",
  "uid": "liderahenk-slo",
  "version": 1
}
