# Stock baseline capture ortami icin ornek env dosyasi.
# Bu dosya, sadece verified stock LiderAhenk kurulumundan
# canonical golden baseline capture almak icin kullanilir.
# Repo'nun aktif .env dosyasini degistirmez.
# Capture onayi zorunludur:
#   BASELINE_CAPTURE_CONFIRM=1 make capture-golden-baseline ...
# Capture oncesi env ve temel erisim kontrolu:
#   BASELINE_ENV_FILE=platform/baselines/stock-capture.env.example make golden-baseline-preflight

# Stock API ve UI yuzeyleri
LIDER_API_URL_EXTERNAL=http://stock-liderapi-host:8082
LIDER_UI_URL=http://stock-liderui-host:3001

# Stock operator kimligi
LIDER_USER=lider-admin
LIDER_PASS=secret

# Stock LDAP erisimi
LDAP_HOST=stock-ldap-host
LDAP_PORT=1389
LDAP_BASE_DN=dc=liderahenk,dc=org
LDAP_ADMIN_USERNAME=admin
LDAP_ADMIN_PASSWORD=DEGISTIR

# Stock MariaDB erisimi
MYSQL_HOST=stock-mariadb-host
MYSQL_PORT=3306
MYSQL_DATABASE=liderahenk
MYSQL_USER=lider
MYSQL_PASSWORD=DEGISTIR

# Stock XMPP / baseline metadata
XMPP_DOMAIN=liderahenk.org
GOLDEN_BASELINE_NAME=stock-liderahenk
BASELINE_SOURCE_LABEL=stock-install-2026-03

# Not:
# - Bu dosyadaki host/port alanlari stock ortamin resmi yuzeyleri olmalidir.
# - Secret alanlari kendi stock ortamina gore degistir.
# - Bu dosyayi patch'li dev runtime icin kullanma.
