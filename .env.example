# ============================
# LiderAhenk Test Ortamı
# ============================

# --- Sürümler ---
LIDER_VERSION=3.x
AHENK_VERSION=2.0.1
AHENK_UPSTREAM_SHA=c0f216b05c335883d5b35bf606eac39bcb98b4bd
# ÖNEMLİ: latest KULLANMA! 25.03 Mnesia bozuyor
EJABBERD_VERSION=24.02

# --- LDAP (Bitnami OpenLDAP) ---
LDAP_ROOT=dc=liderahenk,dc=org
LDAP_ADMIN_USERNAME=admin
LDAP_ADMIN_PASSWORD=DEGISTIR
LDAP_PORT=1389
LDAP_BASE_DN=dc=liderahenk,dc=org
LDAP_AGENT_BASE_DN=ou=Ahenkler,dc=liderahenk,dc=org

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=DEGISTIR
MYSQL_DATABASE=liderahenk
MYSQL_USER=lider
MYSQL_PASSWORD=DEGISTIR

# --- XMPP (ejabberd) ---
XMPP_HOST=ejabberd
XMPP_DOMAIN=liderahenk.org
XMPP_ADMIN_PASS=secret
XMPP_AGENT_PASS=secret
XMPP_RESOURCE=LiderAPI

# --- Ahenk Simülasyonu ---
AHENK_COUNT=10
JITTER_MAX_SECONDS=30
CONTAINER_MODE=1
DEBUG_MODE=0
ENABLE_LEGACY_REGISTRATION_SIM=0
LIDER_FEATURE_PROFILE=v1-broad
UI_DISABLED_FEATURES=ad,guacamole,remote-access,conky,usb,ldap-login,session-power,manage-root,service-management,file-transfer,browser,browser-chrome,disk-quota,rsyslog
AHENK_AGENT_MODE=semi-privileged
AHENK_RUN_AS_ROOT=1
NETWORK_PORT_RULE_MODE=shadow
PLATFORM_EXPORTER_INTERVAL_SECONDS=15
OTEL_JAVA_AGENT_VERSION=2.23.0

# --- Lider API ---
LIDER_API_URL=http://liderapi:8080
LIDER_API_VERSION=v1
LIDER_USER=lider-admin
LIDER_PASS=secret
